#include "DFRobotDFPlayerMini.h"

HardwareSerial mySerial(2); 
DFRobotDFPlayerMini myDFPlayer;

void setup() {
  Serial.begin(115200);
  delay(2000); // biar DFPlayer siap dulu

  // RX = 25, TX = 26
  mySerial.begin(9600, SERIAL_8N1, 25, 26);

  Serial.println("Init DFPlayer...");

  if (!myDFPlayer.begin(mySerial)) {
    Serial.println("❌ DFPlayer tidak terdeteksi!");
    while (true);
  }

  Serial.println("✅ DFPlayer siap!");

  myDFPlayer.volume(30);   // max dulu buat test
  delay(1000);

  Serial.println("▶️ Play file 0001.mp3");
  myDFPlayer.play(1);      // file pertama (0001.mp3)
}

void loop() {
  // ulang tiap 10 detik
  delay(10000);
  Serial.println("🔁 Ulang...");
  myDFPlayer.play(1);
}
