#include <TinyGPS++.h>
#include <HardwareSerial.h>

// Inisialisasi GPS dan Serial
TinyGPSPlus gps;
HardwareSerial SerialGPS(2); // Menggunakan UART2 (RX2, TX2)

void setup() {
  Serial.begin(115200);
  // Baud rate standar GT-U7 adalah 9600
  SerialGPS.begin(9600, SERIAL_8N1, 16, 17); 
  
  Serial.println("Mencari Sinyal Satelit...");
}

void loop() {
  // Baca data dari modul GPS
  while (SerialGPS.available() > 0) {
    if (gps.encode(SerialGPS.read())) {
      displayInfo();
    }
  }

  // Jika setelah 5 detik tidak ada sinyal
  if (millis() > 5000 && gps.charsProcessed() < 10) {
    Serial.println("GPS tidak terdeteksi, periksa kabel!");
    delay(1000);
  }
}

void displayInfo() {
  if (gps.location.isValid()) {
    float latitude = gps.location.lat();
    float longitude = gps.location.lng();
    
    Serial.print("Latitude: "); Serial.println(latitude, 6);
    Serial.print("Longitude: "); Serial.println(longitude, 6);
    Serial.print("Speed: "); Serial.println(gps.speed.kmph());
    
    // Panggil fungsi kirim data ke internet di sini
    // sendDataToCloud(latitude, longitude);
  } else {
    Serial.println("Mencari posisi (GPS Fix)...");
  }
}
